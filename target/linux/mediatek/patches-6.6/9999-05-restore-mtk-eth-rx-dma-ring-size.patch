From: Yuzhii0718 <admin@yuzhii0718.eu.org>
Date: Tue, 2 Jun 2026 21:59:23 +8000
Subject: [PATCH] 9999-06-restore-mtk-eth-rx-dma-ring-size

Bumping from 6.6.95 to 6.6.133 reduced the RX DMA descriptor ring
size across multiple MediaTek SoC configurations:

  mt2701/mt7621/mt7622/mt7623/mt7629: 2K -> 512
  mt7981 (Filogic 820):               2K -> 512
  mt7986 (Filogic 830):               2K -> 1K
  mt7988 (Filogic 880):               2K -> 1K
  rt5350:                             2K -> 256

MT7981 went from 2048 to 512 descriptors (75% reduction), severely
limiting RX buffering capacity. Under moderate to high network load,
the smaller ring fills up rapidly, causing:

 - RX ring overflow / hardware packet drops
 - Network throughput fluctuations
 - Stuttering and increased latency
 - General network instability

Restore all RX DMA descriptor ring sizes to their 6.6.95 values (2K)
to ensure adequate RX buffering headroom.

--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
@@ -6897,7 +6897,7 @@
 	.rx = {
 		.desc_size = sizeof(struct mtk_rx_dma),
 		.dma_l4_valid = RX_DMA_L4_VALID,
-		.dma_size = MTK_DMA_SIZE(512),
+		.dma_size = MTK_DMA_SIZE(2K),
 		.dma_max_len = MTK_TX_DMA_BUF_LEN,
 		.dma_len_offset = 16,
 	},
@@ -6925,7 +6925,7 @@
 	.rx = {
 		.desc_size = sizeof(struct mtk_rx_dma),
 		.dma_l4_valid = RX_DMA_L4_VALID,
-		.dma_size = MTK_DMA_SIZE(512),
+		.dma_size = MTK_DMA_SIZE(2K),
 		.dma_max_len = MTK_TX_DMA_BUF_LEN,
 		.dma_len_offset = 16,
 	},
@@ -6955,7 +6955,7 @@
 	.rx = {
 		.desc_size = sizeof(struct mtk_rx_dma),
 		.dma_l4_valid = RX_DMA_L4_VALID,
-		.dma_size = MTK_DMA_SIZE(512),
+		.dma_size = MTK_DMA_SIZE(2K),
 		.dma_max_len = MTK_TX_DMA_BUF_LEN,
 		.dma_len_offset = 16,
 	},
@@ -6984,7 +6984,7 @@
 	.rx = {
